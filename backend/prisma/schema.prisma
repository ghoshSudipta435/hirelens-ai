generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  RECRUITER
}

enum ResumeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum JobPostingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum LocationMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  SUBMITTED
  REVIEWED
  SHORTLISTED
  REJECTED
}

enum MatchContextType {
  APPLICATION
  PREVIEW
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AuthEventType {
  REGISTER
  LOGIN
  REFRESH
  LOGOUT
  PROFILE
}

enum UploadAuditEventType {
  UPLOAD_CREATE
  UPLOAD_GET
  UPLOAD_DELETE
}

enum ResumeAuditEventType {
  RESUME_CREATED
  RESUME_UPDATED
  RESUME_DELETED
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  passwordHash   String
  role           UserRole
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  resumes         Resume[]
  jobPostings     JobPosting[]
  studentProfile  StudentProfile?
  recruiterProfile RecruiterProfile?
  refreshTokens   RefreshToken[]
  authAuditEvents AuthAuditEvent[]
  uploadedFiles   UploadedFile[]
  uploadAuditEvents UploadAuditEvent[]
  resumeAuditEvents ResumeAuditEvent[]
}

model StudentProfile {
  userId         String   @id
  fullName       String?
  headline       String?
  university     String?
  degree         String?
  graduationYear Int?
  githubUrl      String?
  linkedinUrl    String?
  portfolioUrl   String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecruiterProfile {
  userId        String   @id
  companyName   String?
  companyWebsite String?
  designation   String?
  bio           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id              String         @id @default(cuid())
  ownerId         String
  uploadedFileId  String         @unique
  title           String
  version         Int
  status          ResumeStatus   @default(DRAFT)
  parsedData      Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  owner           User           @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  uploadedFile    UploadedFile   @relation(fields: [uploadedFileId], references: [id], onDelete: Restrict)
  applications    Application[]
  matchResults    MatchResult[]

  @@index([ownerId, status])
  @@index([ownerId, deletedAt])
}

model JobPosting {
  id              String           @id @default(cuid())
  recruiterId     String
  title           String
  description     String
  extractedSkills String[]
  employmentType  EmploymentType
  locationMode    LocationMode
  status          JobPostingStatus @default(DRAFT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  recruiter       User             @relation(fields: [recruiterId], references: [id], onDelete: Restrict)
  applications    Application[]
  matchResults    MatchResult[]

  @@index([recruiterId, status])
  @@index([status, createdAt])
  @@index([employmentType, locationMode])
}

model Application {
  id             String            @id @default(cuid())
  resumeId       String
  jobPostingId   String
  status         ApplicationStatus @default(SUBMITTED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  resume         Resume            @relation(fields: [resumeId], references: [id], onDelete: Restrict)
  jobPosting     JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Restrict)
  matchResults   MatchResult[]

  @@unique([resumeId, jobPostingId])
  @@index([jobPostingId, status])
  @@index([resumeId])
  @@index([createdAt])
  @@index([deletedAt])
}

model MatchResult {
  id                String           @id @default(cuid())
  contextType       MatchContextType
  resumeId          String
  jobPostingId      String?
  applicationId     String?
  score             Int
  matchedSkills     String[]
  missingSkills     String[]
  strengths         String[]
  improvements      String[]
  scoreVersion      String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  resume            Resume           @relation(fields: [resumeId], references: [id], onDelete: Restrict)
  jobPosting        JobPosting?      @relation(fields: [jobPostingId], references: [id], onDelete: Restrict)
  application       Application?     @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  questionSets      InterviewQuestionSet[]

  @@index([resumeId, createdAt])
  @@index([jobPostingId, createdAt])
  @@index([applicationId, createdAt])
  @@index([score])
  @@index([deletedAt])
}

model InterviewQuestionSet {
  id             String              @id @default(cuid())
  matchResultId  String
  createdAt      DateTime            @default(now())
  matchResult    MatchResult         @relation(fields: [matchResultId], references: [id], onDelete: Restrict)
  questions      InterviewQuestion[]

  @@index([matchResultId])
}

model InterviewQuestion {
  id             String              @id @default(cuid())
  questionSetId  String
  question       String
  difficulty     QuestionDifficulty
  category       String
  createdAt      DateTime            @default(now())
  questionSet    InterviewQuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)

  @@index([questionSetId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthAuditEvent {
  id         String       @id @default(cuid())
  eventType  AuthEventType
  success    Boolean
  userId     String?
  email      String?
  reason     String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime     @default(now())
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
}

model UploadedFile {
  id                 String   @id @default(cuid())
  ownerId            String
  fileName           String
  fileType           String
  fileSize           Int
  cloudinaryPublicId String   @unique
  fileUrl            String
  createdAt          DateTime @default(now())
  deletedAt          DateTime?
  owner              User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  resume             Resume?

  @@index([ownerId, createdAt])
  @@index([ownerId, deletedAt])
}

model UploadAuditEvent {
  id             String               @id @default(cuid())
  eventType      UploadAuditEventType
  success        Boolean
  ownerId        String?
  uploadedFileId String?
  fileName       String?
  reason         String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  owner          User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([ownerId, createdAt])
  @@index([uploadedFileId, createdAt])
}

model ResumeAuditEvent {
  id         String               @id @default(cuid())
  eventType  ResumeAuditEventType
  success    Boolean
  ownerId    String?
  resumeId   String?
  reason     String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime             @default(now())
  owner      User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([ownerId, createdAt])
  @@index([resumeId, createdAt])
}
