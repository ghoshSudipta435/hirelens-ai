generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  RECRUITER
}

enum ResumeStatus {
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum JobPostingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum LocationMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  SUBMITTED
  REVIEWED
  SHORTLISTED
  REJECTED
}

enum MatchContextType {
  APPLICATION
  PREVIEW
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AuthEventType {
  REGISTER
  LOGIN
  REFRESH
  LOGOUT
  PROFILE
}

enum UploadResourceType {
  IMAGE
  RAW
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  passwordHash   String
  role           UserRole
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  resumes         Resume[]
  jobPostings     JobPosting[]
  studentProfile  StudentProfile?
  recruiterProfile RecruiterProfile?
  refreshTokens   RefreshToken[]
  authAuditEvents AuthAuditEvent[]
  uploads         Upload[]
}

model StudentProfile {
  userId         String   @id
  fullName       String?
  headline       String?
  university     String?
  degree         String?
  graduationYear Int?
  githubUrl      String?
  linkedinUrl    String?
  portfolioUrl   String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecruiterProfile {
  userId        String   @id
  companyName   String?
  companyWebsite String?
  designation   String?
  bio           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id              String         @id @default(cuid())
  userId          String
  label           String?
  fileUrl         String
  originalName    String
  mimeType        String
  fileSizeBytes   Int
  parsedText      String?
  extractedSkills String[]
  status          ResumeStatus   @default(PROCESSING)
  isDefault       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  applications    Application[]
  matchResults    MatchResult[]

  @@index([userId, createdAt])
}

model JobPosting {
  id              String           @id @default(cuid())
  recruiterId     String
  title           String
  description     String
  extractedSkills String[]
  employmentType  EmploymentType
  locationMode    LocationMode
  status          JobPostingStatus @default(DRAFT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  recruiter       User             @relation(fields: [recruiterId], references: [id], onDelete: Restrict)
  applications    Application[]
  matchResults    MatchResult[]

  @@index([recruiterId, status])
}

model Application {
  id             String            @id @default(cuid())
  resumeId       String
  jobPostingId   String
  status         ApplicationStatus @default(SUBMITTED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  resume         Resume            @relation(fields: [resumeId], references: [id], onDelete: Restrict)
  jobPosting     JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Restrict)
  matchResults   MatchResult[]

  @@unique([resumeId, jobPostingId])
  @@index([jobPostingId, status])
}

model MatchResult {
  id                String           @id @default(cuid())
  contextType       MatchContextType
  resumeId          String
  jobPostingId      String?
  applicationId     String?
  score             Int
  matchedSkills     String[]
  missingSkills     String[]
  strengths         String[]
  scoreVersion      String
  createdAt         DateTime         @default(now())
  resume            Resume           @relation(fields: [resumeId], references: [id], onDelete: Restrict)
  jobPosting        JobPosting?      @relation(fields: [jobPostingId], references: [id], onDelete: Restrict)
  application       Application?     @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  questionSets      InterviewQuestionSet[]

  @@index([resumeId, createdAt])
  @@index([jobPostingId, createdAt])
  @@index([applicationId, createdAt])
}

model InterviewQuestionSet {
  id             String              @id @default(cuid())
  matchResultId  String
  createdAt      DateTime            @default(now())
  matchResult    MatchResult         @relation(fields: [matchResultId], references: [id], onDelete: Restrict)
  questions      InterviewQuestion[]
}

model InterviewQuestion {
  id             String              @id @default(cuid())
  questionSetId  String
  question       String
  difficulty     QuestionDifficulty
  category       String
  createdAt      DateTime            @default(now())
  questionSet    InterviewQuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthAuditEvent {
  id         String       @id @default(cuid())
  eventType  AuthEventType
  success    Boolean
  userId     String?
  email      String?
  reason     String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime     @default(now())
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
}

model Upload {
  id                  String            @id @default(cuid())
  userId              String
  originalName        String
  fileExtension       String
  mimeType            String
  fileSizeBytes       Int
  cloudinaryPublicId  String            @unique
  cloudinarySecureUrl  String
  cloudinaryResourceType UploadResourceType
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, deletedAt])
}
